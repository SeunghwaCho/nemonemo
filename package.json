{
  "name": "nemonemo",
  "version": "1.0.0",
  "description": "2D 네모네모 로직 웹 게임",
  "scripts": {
    "generate": "node scripts/generateLevels.js",
    "build": "node scripts/generateLevels.js && ./node_modules/.bin/esbuild src/main.ts --bundle --outfile=dist/dist.js --target=es2017",
    "test": "./node_modules/.bin/ts-node --project tsconfig.test.json tests/nonogram.test.ts",
    "dev": "node scripts/generateLevels.js && ./node_modules/.bin/esbuild src/main.ts --bundle --outfile=dist/dist.js --watch"
  },
  "devDependencies": {
    "typescript": "^5.3.3",
    "esbuild": "^0.20.0",
    "ts-node": "^10.9.2"
  }
}
